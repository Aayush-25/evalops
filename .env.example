# Full psycopg2 connection string
DATABASE_URL=postgresql://evalops_user:your_password@localhost:5432/evalops

# Password used by Docker Compose for the postgres container
POSTGRES_PASSWORD=your_password

# OpenAI API key — required for RAGAS evaluation scoring
OPENAI_API_KEY=sk-...

# FastAPI bind host (default: 0.0.0.0)
API_HOST=0.0.0.0

# FastAPI bind port (default: 8000)
API_PORT=8000

# EvalOps API base URL — used by the Streamlit dashboard
API_URL=http://localhost:8000
